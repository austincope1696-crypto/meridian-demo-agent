# Server
PORT=3000

# GoHighLevel CRM webhook (paste your inbound webhook URL from GHL)
GHL_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/YOUR_LOCATION_ID/webhook-trigger/YOUR_HOOK_ID

# Cal.com booking
CALCOM_API_KEY=cal_live_xxxxxxxxxxxxxxxxxxxx
CALCOM_EVENT_TYPE_ID=123456

# Savannah system prompt variables (injected at runtime)
MERIDIAN_BOOKING_WINDOW=weekdays 9am-5pm ET
TEAM_NAME=the Meridian team
CALLBACK_TIMEFRAME=within one business day
